# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000
DASHBOARD_URL=http://localhost:3001
WEB_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/indialeads

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-here
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your-refresh-token-secret-minimum-32-characters
REFRESH_TOKEN_EXPIRES_IN=30d

# ── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_S3_BUCKET=indialeads-uploads-dev

# ── WhatsApp Cloud API ────────────────────────────────────────────────────────
# Get these from Meta Developer Console → WhatsApp → API Setup
WA_APP_ID=1234567890
WA_APP_SECRET=your_app_secret_here
WA_VERIFY_TOKEN=your_custom_webhook_verify_token   # you choose this
WA_API_VERSION=v19.0
WA_BASE_URL=https://graph.facebook.com

# ── Encryption ────────────────────────────────────────────────────────────────
# Used to AES-256 encrypt wa_access_token in the database
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here

# ── Rate Limiting ─────────────────────────────────────────────────────────────
WA_MESSAGES_PER_SECOND=3
DAILY_MESSAGE_LIMIT=1000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ── Broadcast Delays (milliseconds) ──────────────────────────────────────────
BROADCAST_DELAY_MIN_MS=20000    # 20 seconds
BROADCAST_DELAY_MAX_MS=40000    # 40 seconds

# ── Lead Management ───────────────────────────────────────────────────────────
COOLING_PERIOD_DAYS=7
